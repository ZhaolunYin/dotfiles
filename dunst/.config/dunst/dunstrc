[global]
    monitor = 0
    follow = mouse
    width = 320
    height = 120
    offset = 20x20
    origin = top-right

    transparency = 0
    frame_width = 2
    frame_color = "#89b4fa"

    separator_height = 2
    separator_color = "#1c1c2e"

    corner_radius = 8

    font = JetBrainsMono Nerd Font 11
    line_height = 4

    padding = 12
    horizontal_padding = 12

    show_age_threshold = 60
    idle_threshold = 120

    markup = full
    format = "<b>%s</b>\n%b"

    alignment = left
    vertical_alignment = center

    icon_position = left
    min_icon_size = 24
    max_icon_size = 32

    sticky_history = yes
    history_length = 20

    browser = firefox
    always_run_script = true

    title = Dunst
    class = Dunst

[global]
frame_color = "#89b4fa"
separator_color= frame
highlight = "#89b4fa"

[urgency_low]
background = "#1e1e2e"
foreground = "#cdd6f4"

[urgency_normal]
background = "#1e1e2e"
foreground = "#cdd6f4"

[urgency_critical]
background = "#1e1e2e"
foreground = "#cdd6f4"
frame_color = "#fab387"
